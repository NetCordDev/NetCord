{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "Group all non-major NuGet updates into one PR",
      "matchDatasources": [ "nuget" ],
      "matchUpdateTypes": [ "minor", "patch", "pin", "digest" ],
      "groupName": "NuGet non-major"
    },
    {
      "description": "Schedule dotnet-sdk updates weekly on Wednesday",
      "matchPackageNames": [ "dotnet-sdk" ],
      "schedule": [ "on wednesday" ]
    },
    {
      "description": "Group all non-major npm updates into one PR",
      "matchDatasources": [ "npm" ],
      "matchUpdateTypes": [ "minor", "patch", "pin", "digest" ],
      "groupName": "npm non-major"
    },
    {
      "description": "Group non-major GitHub Actions updates",
      "matchManagers": [ "github-actions" ],
      "matchUpdateTypes": [ "minor", "patch", "pin", "digest" ],
      "groupName": "GitHub Actions non-major"
    }
  ]
}
