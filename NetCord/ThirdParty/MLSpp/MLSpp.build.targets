<Project>

	<!-- Clean mlspp CMake build directory when MSBuild Clean is executed -->
	<Target Name="CleanMlsppNative"
			DependsOnTargets="PopulateMlsppBaseProps"
			Condition="'$(AlsoCleanMlspp)' == 'true'">
		
		<Message Text="Cleaning mlspp CMake build directory: $(MlsppBuildDir)" Importance="high" Condition="Exists('$(MlsppBuildDir)')" />

		<!-- Remove the entire build directory to clean CMake cache and build artifacts -->
		<RemoveDir Directories="$(MlsppBuildDir)" Condition="Exists('$(MlsppBuildDir)')" />

		<Message Text="mlspp CMake build directory cleaned successfully" Importance="high" Condition="Exists('$(MlsppBuildDir)')" />
	</Target>

	<Target Name="PopulateMlsppBaseProps">

		<!-- Build CMake arguments for mlspp -->
		<PropertyGroup>
			<_MlsppCMakeArgs Condition="'$(MlsppGenerator)' != ''">-G "$(MlsppGenerator)"</_MlsppCMakeArgs>

			<_MlsppCMakeArgs Condition="'@(CMakeConfiguration)' != ''"
							>$(_MlsppCMakeArgs) -DCMAKE_CONFIGURATION_TYPES="@(CMakeConfiguration)"</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'@(CMakeConfiguration)' == ''"
							  >$(_MlsppCMakeArgs) -DCMAKE_BUILD_TYPE="$(Configuration)"</_MlsppCMakeArgs>

			<_MlsppCMakeArgs>$(_MlsppCMakeArgs) -DDISABLE_PQ=ON -DMLS_CXX_NAMESPACE="mlspp" -DDISABLE_GREASE=ON</_MlsppCMakeArgs>
			
			<_MlsppCMakeArgs Condition="'$(MlsppTesting)' != ''">$(_MlsppCMakeArgs) -DTESTING=$(MlsppTesting)</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeOpenSSLRoot)' != ''">$(_MlsppCMakeArgs) -DOpenSSL_ROOT="$(CMakeOpenSSLRoot) "</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeOpenSSLDir)' != ''">$(_MlsppCMakeArgs) -DOpenSSL_DIR="$(CMakeOpenSSLDir) "</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeBoringSSLRoot)' != ''">$(_MlsppCMakeArgs) -DBoringSSL_ROOT="$(CMakeBoringSSLRoot) "</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeBoringSSLDir)' != ''">$(_MlsppCMakeArgs) -DBoringSSL_DIR="$(CMakeBoringSSLDir) "</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeNlohmannJsonRoot)' != ''">$(_MlsppCMakeArgs) -Dnlohmann_json_ROOT="$(CMakeNlohmannJsonRoot) "</_MlsppCMakeArgs>
			<_MlsppCMakeArgs Condition="'$(CMakeNlohmannJsonDir)' != ''">$(_MlsppCMakeArgs) -Dnlohmann_json_DIR="$(CMakeNlohmannJsonDir) "</_MlsppCMakeArgs>

			<_MlsppInstallPath Condition="'$(MlsppBaseInstallPath)' != ''">$(MlsppBaseInstallPath)</_MlsppInstallPath>
			<_MlsppInstallPath Condition="'$(CMakeInstallPrefix)' != ''">$(CMakeInstallPrefix)\$(_MlsppInstallPath)</_MlsppInstallPath>
			<_MlsppInstallPath Condition="'$(MlsppInstallPath)' != ''">$(MlsppInstallPath)</_MlsppInstallPath>
			<_MlsppCMakeArgs Condition="'$(_MlsppInstallPath)' != ''">$(_MlsppCMakeArgs) -DCMAKE_INSTALL_PREFIX="$(_MlsppInstallPath) "</_MlsppCMakeArgs>

			<MlsppBuildDir Condition="'$(MlsppBuildDir)' == ''">$(MlsppBaseBuildDir)\$(RuntimeIdentifier)\</MlsppBuildDir>
			<_MlsppBuildDirPreType>$(MlsppBuildDir)</_MlsppBuildDirPreType>
			
			<MlsppCMakeBuildArgs>$(CMakeBuildArgs) $(MlsppCMakeBuildArgs)</MlsppCMakeBuildArgs>
			<MlsppCMakeBuildArgs Condition="'$(OS)' == 'Windows_NT'">--config $(Configuration) $(MlsppCMakeBuildArgs)</MlsppCMakeBuildArgs>
			<MlsppCMakeBuildArgs>--parallel $(MlsppCMakeBuildArgs)</MlsppCMakeBuildArgs>
		</PropertyGroup>

	</Target>
	
	<Target Name="MlsppPopulateProps"
			DependsOnTargets="PopulateMlsppBaseProps">

		<Warning Condition="'$(MlsppInstallPath)' != '' AND '$(CMakeInstallPrefix)' != ''"
				 Text="&lt;MlsppInstallPath&gt; and &lt;CMakeInstallPrefix&gt; are mutually exclusive. '$(CMakeInstallPrefix)' will be ignored in favor of '$(MlsppInstallPath)'." />

		<PropertyGroup>
			<MlsppBuildDir>$(MlsppBuildDir)\static</MlsppBuildDir>
		</PropertyGroup>

		<PropertyGroup Condition="'$(CMakeStaticRT)' == 'true'">
			<MlsppBuildDir>$(MlsppBuildDir)_rt</MlsppBuildDir>

			<_MlsppCMakeArgs Condition="'$(OS)' == 'Windows_NT'">$(_MlsppCMakeArgs) -DOPENSSL_MSVC_STATIC_RT=ON -DCMAKE_PROJECT_mlspp_INCLUDE="$(MSBuildThisFileDirectory)\..\fix_msvc.cmake"</_MlsppCMakeArgs>
		
			<!--<_MlsppStaticFlags>-static -static-libstdc++ -static-libgcc</_MlsppStaticFlags>-->
			<!--<_MlsppCMakeArgs>$(_MlsppCMakeArgs) -DCMAKE_CXX_FLAGS="$(CMakeFlags) $(MlsppCMakeFlags) $(_MlsppStaticFlags)"</_MlsppCMakeArgs>-->
		</PropertyGroup>

		<ItemGroup>
			<_MlsppLibExt Include="lib;a" />
			
			<_MlsppCMakeConfig Include="@(CMakeConfiguration)">
				<MSBuildProperties>%(MSBuildProperties);Configuration=%(Identity);CMakeStaticRT=$(CMakeStaticRT)</MSBuildProperties>
				<_OutputPath>$(MlsppBuildDir)\%(Identity)</_OutputPath>
			</_MlsppCMakeConfig>
		
			<_MlsppCMakeConfig Update="%(Identity)" Condition="'$(MlsppGenerator)' == '' AND '$(OS)' != 'Windows_NT'">
				<_OutputPath>%(_OutputPath)\$(MlsppBuildOutBaseDir)</_OutputPath>
			</_MlsppCMakeConfig>
		</ItemGroup>

		<PropertyGroup Condition="'$(MlsppGenerator)' == ''">
			<MlsppBuildDir Condition="'$(OS)' != 'Windows_NT'">$(MlsppBuildDir)\$(Configuration)\</MlsppBuildDir>

			<_MlsppCMakeOutDir>$(MlsppBuildDir)</_MlsppCMakeOutDir>
			<_MlsppCMakeOutDir Condition="'$(OS)' != 'Windows_NT'">$(_MlsppCMakeOutDir)\$(MlsppBuildOutBaseDir)</_MlsppCMakeOutDir>
			
			<_MlsppCMakeArgs>$(_MlsppCMakeArgs) -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=$(_MlsppCMakeOutDir)</_MlsppCMakeArgs>
			<_MlsppCMakeArgs>$(_MlsppCMakeArgs) -DCMAKE_LIBRARY_OUTPUT_DIRECTORY=$(_MlsppCMakeOutDir)</_MlsppCMakeArgs>
			<_MlsppCMakeArgs>$(_MlsppCMakeArgs) -DCMAKE_ARCHIVE_OUTPUT_DIRECTORY=$(_MlsppCMakeOutDir)</_MlsppCMakeArgs>
		
			<_MlsppBuildOutputPath>$(MlsppBuildDir)\$(Configuration)</_MlsppBuildOutputPath>
			<MlsppCMakeBuildArgs Condition="'$(OS)' == 'Windows_NT'"
								 >$(MlsppCMakeBuildArgs) -- /p:OutDir="$(_MlsppBuildOutputPath)/"</MlsppCMakeBuildArgs>
			
			<_MlsppBuildOutputPath Condition="'$(OS)' != 'Windows_NT'">$(MlsppBuildDir)\$(MlsppBuildOutBaseDir)</_MlsppBuildOutputPath>
		</PropertyGroup>

		<PropertyGroup>
			<MlsppCMakeArgs>$(_MlsppCMakeArgs) $(CMakeArgs) $(MlsppCMakeArgs)</MlsppCMakeArgs>

			<_MlsppConfigureCMakeArgsFile>$(MlsppBuildDir)\.cmake-args</_MlsppConfigureCMakeArgsFile>
			<_MlsppConfigureErrorLog>$(MlsppBuildDir)\.cmake-configure-error.log</_MlsppConfigureErrorLog>
			
			<_MlsppBuildErrorLog>$(MlsppBuildDir)\.cmake-build-error_$(Configuration).log</_MlsppBuildErrorLog>
			<_MlsppBuildErrorIdent>$(MlsppBuildDir)\build_error_$(Configuration)</_MlsppBuildErrorIdent>

			<_MlsppInstallErrorLog>$(MlsppBuildDir)\.cmake-install-error_$(Configuration).log</_MlsppInstallErrorLog>
		</PropertyGroup>
		
	</Target>

	<Target Name="CheckReconfigureMlspp"
			DependsOnTargets="MlsppPopulateProps">

		<!-- Read previous value if file exists -->
		<ReadLinesFromFile File="$(_MlsppConfigureCMakeArgsFile)" 
					   Condition="Exists('$(_MlsppConfigureCMakeArgsFile)')">
			<Output TaskParameter="Lines" ItemName="_PrevCMakeArgs" />
		</ReadLinesFromFile>

		<!-- Copy previous args -->
		<PropertyGroup Condition="Exists('$(_MlsppConfigureCMakeArgsFile)')">
			<_PrevCMakeArgsProperty>%(_PrevCMakeArgs.Identity)</_PrevCMakeArgsProperty>
		</PropertyGroup>

		<!-- Normalize / trim both sides, then compare ordinally -->
		<PropertyGroup>
			<_PrevCMakeArgsTrimmed>$(_PrevCMakeArgsProperty.Trim())</_PrevCMakeArgsTrimmed>
			<_MlsppCMakeArgsTrimmed>$(MlsppCMakeArgs.Trim())</_MlsppCMakeArgsTrimmed>

			<_IsCMakeArgsChanged_>
				$([System.String]::Compare('$(_MlsppCMakeArgsTrimmed)', '$(_PrevCMakeArgsTrimmed)'))
			</_IsCMakeArgsChanged_>
			<_IsCMakeArgsChanged>$(_IsCMakeArgsChanged_.Trim())</_IsCMakeArgsChanged>
		</PropertyGroup>

		<Message Condition="'$(_IsCMakeArgsChanged)' != '0'" Text="CMakeArgs used has Changed." Importance="high" />
		<Message Condition="'$(_IsCMakeArgsChanged)' != '0'" Text="Previous CMakeArgs: [$(_PrevCMakeArgsTrimmed)]." Importance="high" />

		<PropertyGroup>
			<_IsCMakeArgsChanged Condition="'$(CMakeClearCache)' == 'true' AND '$(_IsCMakeArgsChanged)' != '0'">-1</_IsCMakeArgsChanged>
		</PropertyGroup>

		<Delete Files="$(MlsppBuildDir)\CMakeCache.txt" Condition="'$(CMakeClearCache)' == 'true' AND '$(_IsCMakeArgsChanged)' != '0'" />

		<PropertyGroup>
			<_IsCMakeArgsChanged Condition="!Exists('$(MlsppBuildDir)\CMakeCache.txt')">-1</_IsCMakeArgsChanged>
		</PropertyGroup>
		
		<!--Ensure build directory exists-->
		<MakeDir Directories="$(MlsppBuildDir)" Condition="!Exists('$(MlsppBuildDir)')" />
		
		<Touch AlwaysCreate="true" Condition="'$(_IsCMakeArgsChanged)' != '0' OR !Exists('$(MlsppBuildDir)\.cmake-configure')"
			   Files="$(MlsppBuildDir)\.cmake-configure" />

	</Target>

	<Target Name="ConfigureMlspp"
			DependsOnTargets="CheckReconfigureMlspp"
			Inputs="$(MlsppCppRoot)\CMakeLists.txt;$(MlsppBuildDir)\.cmake-configure"
			Outputs="$(_MlsppConfigureCMakeArgsFile)"
			Condition="Exists('$(MlsppCppRoot)\CMakeLists.txt')">

		<Message Text="Building mlspp native library from $(MlsppCppRoot)" Importance="high" />
		<Message Text="Build directory: $(MlsppBuildDir)" Importance="high" />

		<!-- Configure CMake (generate build files) for mlspp -->
		<Message Text="Configuring mlspp CMake project..." Importance="high" />
		<Message Text="CMake arguments: $(MlsppCMakeArgs)" Importance="high" />

		<!-- Delete old error log if exists -->
		<Delete Files="$(_MlsppConfigureErrorLog)" Condition="Exists('$(_MlsppConfigureErrorLog)')" />

		<Exec Command="cmake -S &quot;$(MlsppCppRoot.TrimEnd('\'))&quot; -B &quot;$(MlsppBuildDir.TrimEnd('\'))&quot; $(MlsppCMakeArgs) 2&gt;&quot;$(_MlsppConfigureErrorLog)&quot;"
			  WorkingDirectory="$(MlsppBuildDir)"
			  ConsoleToMSBuild="true"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="_MlsppConfigureExitCode" />
		</Exec>

		<!--Check for configure errors-->
		<ReadLinesFromFile File="$(_MlsppConfigureErrorLog)" Condition="Exists('$(_MlsppConfigureErrorLog)')">
			<Output TaskParameter="Lines" ItemName="_MlsppConfigureErrors" />
		</ReadLinesFromFile>

		<Error Text="mlspp CMake configuration failed with exit code $(_MlsppConfigureExitCode):%0D%0A@(_MlsppConfigureErrors, '%0D%0A')"
			   Condition="'$(_MlsppConfigureExitCode)' != '0'" />

		<!-- overwrite and update timestamp -->
		<WriteLinesToFile
			File="$(_MlsppConfigureCMakeArgsFile)"
			Lines="$([MSBuild]::Escape('$(MlsppCMakeArgs)'))"
			Overwrite="true" />
		
	</Target>
	<Target Name="CleanMlsppOutputPath"
			DependsOnTargets="MlsppPopulateProps"
			Inputs="@(MlsppSourceFile);$(_MlsppConfigureCMakeArgsFile)"
			Outputs="$(MlsppBuildDir)\.build-stamp;$(_MlsppBuildOutputPath)\**\*">
		<RemoveDir Directories="$(_MlsppBuildOutputPath)" Condition="Exists('$(_MlsppBuildOutputPath)')" />
		<MakeDir Directories="$(_MlsppBuildOutputPath)" Condition="!Exists('$(_MlsppBuildOutputPath)')" />
	</Target>

	<!-- Build mlspp native library -->
	<Target Name="BuildMlsppNative"
			DependsOnTargets="ConfigureMlspp;CleanMlsppOutputPath"
			Inputs="@(MlsppSourceFile);$(_MlsppConfigureCMakeArgsFile)"
			Outputs="$(MlsppBuildDir)\.build-stamp;$(_MlsppBuildOutputPath)\**\*"
			Condition="'$(BuildMlspp)' == 'true' AND Exists('$(MlsppCppRoot)\CMakeLists.txt')">
		
		<!-- Delete old build error log if exists -->
		<Delete Files="$(_MlsppBuildErrorLog)" Condition="Exists('$(_MlsppBuildErrorLog)')" />

		<Message Text="Building mlspp native library..." Importance="high" />
		<Message Text="CMake build arguments: $(MlsppCMakeBuildArgs)" Importance="high" />

		<!-- Use cmake build for better cross-platform compatibility -->
		<Exec Command="cmake --build &quot;$(MlsppBuildDir.TrimEnd('\'))&quot; $(MlsppCMakeBuildArgs) 2&gt;&quot;$(_MlsppBuildErrorLog)&quot;"
			  WorkingDirectory="$(MlsppBuildDir)"
			  ConsoleToMSBuild="true"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="_MlsppBuildExitCode" />
		</Exec>

		<!--Check for build errors-->
		<ReadLinesFromFile File="$(_MlsppBuildErrorLog)" Condition="Exists('$(_MlsppBuildErrorLog)')">
			<Output TaskParameter="Lines" ItemName="_MlsppBuildErrors" />
		</ReadLinesFromFile>

		 <!--Error with detailed message if build failed--> 
		<Error Text="mlspp CMake build failed with exit code $(_MlsppBuildExitCode):%0D%0A@(_MlsppBuildErrors, '%0D%0A')"
			   Condition="'$(_MlsppBuildExitCode)' != '0'" />

		<!-- Create stamp file to track build completion -->
		<Touch Files="$(MlsppBuildDir)\.build-stamp" AlwaysCreate="true" />

		<Message Text="========================================" Importance="high" />
		<Message Text="mlspp native library built successfully" Importance="high" />
		<Message Text="========================================" Importance="high" />

		<!-- Set mlspp location for use -->
		<PropertyGroup>
			<CMakeMlsppDir>$(MlsppBuildDir)</CMakeMlsppDir>
		</PropertyGroup>
	
		<!-- Set remainding config to build -->
		<ItemGroup Condition="'@(_MlsppCMakeConfig)' != ''">
			<_MlsppCMakeConfigRemain Include="@(_MlsppCMakeConfig)" />
			<_MlsppCMakeConfigRemain Remove="$(Configuration)" />
		</ItemGroup>
		
		<ItemGroup>
			<_MlsppBuildOutput Include="$(_MlsppBuildOutputPath)\**\*"/>
			<_MlsppBuildOutput Update="%(Identity)" Condition="'$(MlsppCopyBuildOutput)' == 'true'">
				<_CopyPath>-> $(MSBuildProjectDirectory)\$(OutputPath)\$(MlsppBaseOutputPath)\$([MSBuild]::MakeRelative('$(_MlsppBuildOutputPath)', '%(FullPath)'))</_CopyPath>
			</_MlsppBuildOutput>
		</ItemGroup>
	</Target>
	
	<Target Name="MlsppOutputs"
			DependsOnTargets="BuildMlsppNative">
		
		<ItemGroup Condition="'$(MlsppCopyBuildOutput)' == 'true'">
			<None Include="@(_MlsppBuildOutputPath)">
				<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
				<TargetPath>$(MlsppBaseOutputPath)\$([MSBuild]::MakeRelative('$(_MlsppBuildOutputPath)', '%(FullPath)'))</TargetPath>
			</None>
		</ItemGroup>

		<Message Text="mlspp outputs:" Importance="high"/>
		<Message Text="  %(_MlsppBuildOutput.Identity) %(_MlsppBuildOutput._CopyPath)" Importance="high"/>
	</Target>

	<Target Name="InstallMlsppAfterBuild"
			DependsOnTargets="MlsppInstall"
			Condition="'$(InstallMlsppAfterBuild)' == 'true'" />
	
	<Target Name="MlsppInstall"
			DependsOnTargets="BuildMlsppNative"
			Inputs="$(MlsppBuildDir)\.build-stamp"
			Outputs="$(_MlsppInstallPath)\**\*">
		
		<Error Text="Mlspp installation path is not specified. Set 'MlsppBaseInstallPath' or 'CMakeInstallPrefix' property to enable installation."
			   Condition="'$(_MlsppInstallPath)' == ''" />

		<Message Text="[Install] mlspp -> $(_MlsppInstallPath)" Importance="high" />

		<Delete Files="$(_MlsppInstallErrorLog)" Condition="Exists('$(_MlsppInstallErrorLog)')" />

		<MakeDir Directories="$(_MlsppInstallPath)" Condition="!Exists('$(_MlsppInstallPath)')" />
		
		<Exec Command="cmake --install &quot;$(MlsppBuildDir.TrimEnd('\'))&quot; 2&gt;&quot;$(_MlsppInstallErrorLog)&quot;"
			  WorkingDirectory="$(MlsppBuildDir)"
			  ConsoleToMSBuild="true"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="_MlsppInstallExitCode" />
		</Exec>

		<ReadLinesFromFile File="$(_MlsppInstallErrorLog)" Condition="Exists('$(_MlsppInstallErrorLog)')">
			<Output TaskParameter="Lines" ItemName="_MlsppInstallErrors" />
		</ReadLinesFromFile>
		
		<Error Text="mlspp CMake install failed with exit code $(_MlsppInstallExitCode):%0D%0A@(_MlsppInstallErrors, '%0D%0A')"
			   Condition="'$(_MlsppInstallExitCode)' != '0'" />

		<ItemGroup>
			<_MlsppInstalled Include="$(_MlsppInstallPath)\**\*"/>
		</ItemGroup>

		<Message Text="Mlspp installed: %(_MlsppInstalled.Identity)" Importance="high" />
	
		<!-- Set libdave location for use -->
		<PropertyGroup>
			<CMakeMlsppDir>$(_MlsppInstallPath)\share\MLSPP\</CMakeMlsppDir>
		</PropertyGroup>

	</Target>

	<Target Name="BuildMlsppMultiConfig"
			DependsOnTargets="MlsppPopulateProps">

		<PropertyGroup>
			<!-- Prepare args -->
			<_Args>$(MlsppCMakeBuildArgs.Replace('=', ' '))</_Args>
			<_Pattern>(?:^|\s)(?:-j|--parallel)\s*(\d+)</_Pattern>
    
			<!-- Check if pattern exists -->
			<_HasParallel>$([System.Text.RegularExpressions.Regex]::IsMatch('$(_Args)', '$(_Pattern)'))</_HasParallel>
    
			<!-- Extract last occurrence if exists -->
			<_TotalJobs Condition="'$(_HasParallel)' == 'True'">$([System.Text.RegularExpressions.Regex]::Match('$(_Args)', '.*(?:-j|--parallel)\s*(\d+)').Groups[1].Value)</_TotalJobs>
			<_TotalJobs Condition="'$(_TotalJobs)' == ''">$([System.Environment]::ProcessorCount)</_TotalJobs>
    
			<!-- Divide by config count -->
			<_ConfigCount>@(_MlsppCMakeConfigRemain->Count())</_ConfigCount>
			<_ConfigCount Condition="'$(_ConfigCount)' == '0' AND '$(Configuration)' != ''">1</_ConfigCount>
			<JobsPerConfig>$([MSBuild]::Divide($(_TotalJobs), $(_ConfigCount)))</JobsPerConfig>
			<JobsPerConfig Condition="$(JobsPerConfig) &lt; 1">1</JobsPerConfig>
		
			<_MlsppIntCMakeBuildArgs Condition="'$(JobsPerConfig)' != '1'">MlsppCMakeBuildArgs=-j$(JobsPerConfig)</_MlsppIntCMakeBuildArgs>
		</PropertyGroup>
  
		<Message Text="Jobs per config: $(JobsPerConfig) (Total: $(_TotalJobs), Configs: $(_ConfigCount))" Importance="High" />
		
		<!-- Create project items with metadata instead of batching -->
		<ItemGroup>
			<_MLsppConfigToBuild Include="$(MSBuildProjectFile)">
				<Properties>$(_MlsppIntCMakeBuildArgs);%(_MlsppCMakeConfigRemain.MSBuildProperties)</Properties>
				<Targets>BuildMlsppNative</Targets>
			</_MLsppConfigToBuild>
		</ItemGroup>
  
		<MSBuild Projects="@(_MLsppConfigToBuild)"
				Targets="%(_MLsppConfigToBuild.Targets)"
				StopOnFirstFailure="true"
				Condition="'@(_MlsppCMakeConfigRemain)' != ''"/>

		<Message Text="All mlspp native library configurations built successfully." Importance="high" />

	</Target>

	<Target Name="PackageMlsppLib" DependsOnTargets="BuildMlsppMultiConfig">
		
		<ItemGroup>
			<_MlsppOuts Include="@(_MlsppCMakeConfig)">
				<_Ext>%(_MlsppLibExt.Identity)</_Ext>
			</_MlsppOuts>
			<_MlsppOuts Update="%(Identity)" Condition="'$(CMakeStaticRT)' == 'true'">
				<_OutputPath>$(_MlsppBuildDirPreType)\static_rt\$([MSBuild]::MakeRelative('$(_MlsppBuildDirPreType)\static', '%(_OutputPath)'))</_OutputPath>
			</_MlsppOuts>

			<_MlsppPackageFiles Include="%(_MlsppOuts._OutputPath)\**\*.%(_MlsppOuts._Ext)" >
				<_Config>%(_MlsppOuts.Identity)</_Config>
				<_OutputPath>%(_MlsppOuts._OutputPath)</_OutputPath>
			</_MlsppPackageFiles>
		</ItemGroup>

		<ItemGroup>
			<None Include="@(_MlsppPackageFiles)">
				<Pack>true</Pack>
				<PackagePath>lib\$(RuntimeIdentifier)\%(_MlsppPackageFiles._Config)\$([MSBuild]::MakeRelative('%(_MlsppPackageFiles._OutputPath)', '%(_MlsppPackageFiles.FullPath)'))</PackagePath>
			</None>

			<None Include="@(_MlsppPackageFiles)" />
		</ItemGroup>

		<Message Text="$(MSBuildProjectName) packaged items:" Importance="high" />
		<Message Text="  %(None.Identity) -> [pkg].\%(None.PackagePath)" Importance="high" Condition="'%(None.Pack)' == 'true'" />

	</Target>

</Project>
