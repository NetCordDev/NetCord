<Project>

	<!-- Clean libdave CMake build directory when MSBuild Clean is executed -->
	<Target Name="CleanLibdaveNative"
			BeforeTargets="Clean"
			Condition="'$(AlsoCleanLibdave)' == 'true' AND Exists('$(LibdaveBuildDir)')">
		
		<Message Text="Cleaning libdave CMake build directory: $(LibdaveBuildDir)" Importance="high" />

		<!-- Remove the entire build directory to clean CMake cache and build artifacts -->
		<RemoveDir Directories="$(LibdaveBuildDir)" />

		<Message Text="libdave CMake build directory cleaned successfully" Importance="high" />
	</Target>
	
	<PropertyGroup>
		<_LibdaveConfigureCMakeArgsFile>$(LibdaveBuildDir)\.cmake-args</_LibdaveConfigureCMakeArgsFile>
	</PropertyGroup>

	<Target Name="CheckForReconfigureLibdave" 
			BeforeTargets="ConfigureLibdave">

		<!-- Build CMake arguments for prebuilt libraries -->
		<PropertyGroup>
			<LibdaveCMakeArgs>$(CMakeArgs) $(LibdaveCMakeArgs)</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(LibdaveGenerator)' != ''">-G "$(LibdaveGenerator)" $(LibdaveCMakeArgs)</LibdaveCMakeArgs>

			<LibdaveCMakeArgs>$(LibdaveCMakeArgs) -DBUILD_SHARED_LIBS=ON</LibdaveCMakeArgs>

			<_LibdaveOutputAbs>$(MSBuildProjectDirectory)\$(OutputPath)</_LibdaveOutputAbs>
			<_LibdaveOutputRel>$([MSBuild]::MakeRelative($(LibdaveBuildDir), $(_LibdaveOutputAbs)))</_LibdaveOutputRel>
			
			<LibdaveCMakeArgs Condition="'$(LibdaveTesting)' != ''">$(LibdaveCMakeArgs) -DTESTING=$(LibdaveTesting) -DTESTS=$(LibdaveTesting)</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeOpenSSLRoot)' != ''">$(LibdaveCMakeArgs) -DOpenSSL_ROOT="$(CMakeOpenSSLRoot)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeOpenSSLDir)' != ''">$(LibdaveCMakeArgs) -DOpenSSL_DIR="$(CMakeOpenSSLDir)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeBoringSSLRoot)' != ''">$(LibdaveCMakeArgs) -DBoringSSL_ROOT="$(CMakeBoringSSLRoot)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeBoringSSLDir)' != ''">$(LibdaveCMakeArgs) -DBoringSSL_DIR="$(CMakeBoringSSLDir)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeNlohmannJsonRoot)' != ''">$(LibdaveCMakeArgs) -Dnlohmann_json_ROOT="$(CMakeNlohmannJsonRoot)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeNlohmannJsonDir)' != ''">$(LibdaveCMakeArgs) -Dnlohmann_json_DIR="$(CMakeNlohmannJsonDir)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeMlsppRoot)' != ''">$(LibdaveCMakeArgs) -DMLSPP_ROOT="$(CMakeMlsppRoot)"</LibdaveCMakeArgs>
			<LibdaveCMakeArgs Condition="'$(CMakeMlsppDir)' != ''">$(LibdaveCMakeArgs) -DMLSPP_DIR="$(CMakeMlsppDir)"</LibdaveCMakeArgs>
		</PropertyGroup>

		<!-- Read previous value if file exists -->
		<ReadLinesFromFile File="$(_LibdaveConfigureCMakeArgsFile)" 
						   Condition="Exists('$(_LibdaveConfigureCMakeArgsFile)')">
			<Output TaskParameter="Lines" ItemName="_PrevCMakeArgs" />
		</ReadLinesFromFile>

		<!-- Copy previous args -->
		<PropertyGroup Condition="Exists('$(_LibdaveConfigureCMakeArgsFile)')">
			<_PrevCMakeArgsProperty>%(_PrevCMakeArgs.Identity)</_PrevCMakeArgsProperty>
		</PropertyGroup>

		<!-- Normalize / trim both sides, then compare ordinally -->
		<PropertyGroup>
			<_PrevCMakeArgsTrimmed>$(_PrevCMakeArgsProperty.Trim())</_PrevCMakeArgsTrimmed>
			<_LibdaveCMakeArgsTrimmed>$(LibdaveCMakeArgs.Trim())</_LibdaveCMakeArgsTrimmed>

			<_IsCMakeArgsChanged_>
				$([System.String]::Compare('$(_LibdaveCMakeArgsTrimmed)', '$(_PrevCMakeArgsTrimmed)'))
			</_IsCMakeArgsChanged_>
		</PropertyGroup>
		<PropertyGroup>
			<_IsCMakeArgsChanged>$(_IsCMakeArgsChanged_.Trim())</_IsCMakeArgsChanged>
		</PropertyGroup>

		<Message Condition="'$(_IsCMakeArgsChanged)' != '0'" Text="CMakeArgs used has Changed." Importance="high" />
		<Message Condition="'$(_IsCMakeArgsChanged)' != '0'" Text="Previous CMakeArgs: [$(_PrevCMakeArgsTrimmed)]." Importance="high" />

		<!-- Ensure build directory exists-->
		<MakeDir Directories="$(LibdaveBuildDir)" Condition="!Exists('$(LibdaveBuildDir)')" />

		<Touch AlwaysCreate="true" Condition="'$(_IsCMakeArgsChanged)' != '0' OR !Exists('$(LibdaveBuildDir)\.cmake-configure')"
			   Files="$(LibdaveBuildDir)\.cmake-configure" />

	</Target>

	<ItemGroup>
		<UpToDateCheckInput Include="$(LibdaveCppRoot)\CMakeLists.txt"/>
		<UpToDateCheckInput Include="$(LibdaveCppRoot)\**\*.h"/>
		<UpToDateCheckInput Include="$(LibdaveCppRoot)\**\*.c"/>
		<UpToDateCheckInput Include="$(LibdaveCppRoot)\**\*.hpp"/>
		<UpToDateCheckInput Include="$(LibdaveCppRoot)\**\*.cpp"/>
	</ItemGroup>
	<PropertyGroup>
		<BuildLibdave_DependsOn>$(BuildLibdave_DependsOn);ConfigureLibdave</BuildLibdave_DependsOn>
	</PropertyGroup>
	<Target Name="ConfigureLibdave"
			DependsOnTargets="$(ConfigureLibdave_DependsOn)"
			Inputs="$(LibdaveCppRoot)\CMakeLists.txt;$(LibdaveBuildDir)\.cmake-configure"
			Outputs="$(LibdaveBuildDir)\CMakeFiles\generate.stamp"
			Condition="Exists('$(LibdaveCppRoot)\CMakeLists.txt')">

		<Message Text="Building libdave native library from $(LibdaveCppRoot)" Importance="high" />
		<Message Text="Build directory: $(LibdaveBuildDir)" Importance="high" />

		<!-- Configure CMake (generate build files) -->
		<Message Text="Configuring CMake project..." Importance="high" />
		<Message Text="CMake arguments: $(LibdaveCMakeArgs)" Importance="high" />

		<!-- Delete old error log if exists -->
		<Delete Files="$(LibdaveConfigureErrorLog)" Condition="Exists('$(LibdaveConfigureErrorLog)')" />

		<Exec Command="cmake -S &quot;$(LibdaveCppRoot)&quot; -B &quot;$(LibdaveBuildDir)&quot; $(LibdaveCMakeArgs) 2&gt;&quot;$(LibdaveConfigureErrorLog)&quot;"
			  ConsoleToMSBuild="true"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="LibdaveCMakeConfigureExitCode" />
		</Exec>

		<!-- Check for configure errors -->
		<ReadLinesFromFile File="$(LibdaveConfigureErrorLog)" Condition="Exists('$(LibdaveConfigureErrorLog)')">
			<Output TaskParameter="Lines" ItemName="CMakeConfigureErrors" />
		</ReadLinesFromFile>

		<Error Text="CMake configuration failed with exit code $(LibdaveCMakeConfigureExitCode):%0D%0A@(CMakeConfigureErrors, '%0D%0A')"
			   Condition="'$(LibdaveCMakeConfigureExitCode)' != '0'" />

		<!-- overwrite and update timestamp -->
		<WriteLinesToFile
			File="$(_LibdaveConfigureCMakeArgsFile)"
		    Lines="$([MSBuild]::Escape('$(LibdaveCMakeArgs)'))"
			Overwrite="true" />
		
	</Target>

	<!-- Build libdave native library -->
	<Target Name="BuildLibdave"
			BeforeTargets="BeforeBuild;CopyFilesToOutputDirectory"
			DependsOnTargets="$(BuildLibdave_DependsOn)"
			Condition="'$(BuildLibdave)' == 'true' AND Exists('$(LibdaveCppRoot)\CMakeLists.txt')">

		<!-- Delete old error log if exists -->
		<Delete Files="$(LibdaveBuildErrorLog)" Condition="Exists('$(LibdaveBuildErrorLog)')" />

		<!-- Use cmake build for better cross-platform compatibility -->
		<Exec Command="cmake --build &quot;$(LibdaveBuildDir)&quot; --config $(Configuration) --parallel 2&gt;&quot;$(LibdaveBuildErrorLog)&quot;"
			  WorkingDirectory="$(LibdaveBuildDir)"
			  ConsoleToMSBuild="true"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="LibdaveCMakeBuildExitCode" />
		</Exec>

		<!--Check for build errors-->
		<ReadLinesFromFile File="$(LibdaveBuildErrorLog)" Condition="Exists('$(LibdaveBuildErrorLog)')">
			<Output TaskParameter="Lines" ItemName="LibdaveCMakeBuildErrors" />
		</ReadLinesFromFile>

		<!--Error with detailed message if build failed-->
		<Error Text="libdave CMake build failed with exit code $(LibdaveCMakeBuildExitCode):%0D%0A@(LibdaveCMakeBuildErrors, '%0D%0A')"
			   Condition="'$(LibdaveCMakeBuildExitCode)' != '0'" />

		<Message Text="========================================" Importance="high" />
		<Message Text="libdave native library built successfully" Importance="high" />
		<Message Text="========================================" Importance="high" />

		<ItemGroup>
			<_LibdaveBuildOutput Include="$(LibdaveBuildDir)\$(Configuration)\**\*" />
			<Content Include="@(_LibdaveBuildOutput)">
				<Pack>true</Pack>
				<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
				<PackagePath>native\$([MSBuild]::MakeRelative('$(LibdaveBuildDir)', '%(_LibdaveBuildOutput.FullPath)'))</PackagePath>
			</Content>
		</ItemGroup>
		
	</Target>

	<!-- Define all configurations to build when packing -->
	<ItemGroup>
		<_LibdaveConfig Include="$(CMakeConfigs)">
			<Dir>$(LibdaveBuildDir)\%(Identity)\</Dir>
		</_LibdaveConfig>
		<_LibdaveConfig Remove="$(Configuration)" />
	</ItemGroup>
	
	<Target Name="BuildLibdavePackage"
			BeforeTargets="_GetPackageFiles"
			DependsOnTargets="$(BuildLibdavePackage_DependsOn);BuildLibdave"
			Outputs="LibdavePackage_%(_LibdaveConfig.Identity)">

		<Message Text="Packing libdave configuration: %(_LibdaveConfig.Identity)" Importance="high" />

		<Delete Files="$(LibdaveBuildDir)\build_error_%(_LibdaveConfig.Identity).log" />

		<Exec Command='cmake --build "$(LibdaveBuildDir)" --config %(_LibdaveConfig.Identity) --parallel 2> "$(LibdaveBuildDir)\build_error_%(_LibdaveConfig.Identity).log"'
			  WorkingDirectory="$(LibdaveBuildDir)"
			  IgnoreExitCode="true"
			  EchoOff="false">
			<Output TaskParameter="ExitCode" PropertyName="LibdaveCMakeBuildExitCode_%(_LibdaveConfig.Identity)" />
		</Exec>

		<ReadLinesFromFile
		  File="$(LibdaveBuildDir)\build_error_%(_LibdaveConfig.Identity).log"
		  Condition="Exists('$(LibdaveBuildDir)\build_error_%(_LibdaveConfig.Identity).log')">
			<Output TaskParameter="Lines" ItemName="LibdaveCMakeBuildErrors_%(_LibdaveConfig.Identity)" />
		</ReadLinesFromFile>

		<Error
		  Text="libdave CMake build failed for configuration %(_LibdaveConfig.Identity):&#x0D;&#x0A;@(LibdaveCMakeBuildErrors_%(_LibdaveConfig.Identity), '&#x0D;&#x0A;')"
		  Condition="'$(LibdaveCMakeBuildExitCode_%(_LibdaveConfig.Identity))' != '0'" />

		<Message Text="Libdave configuration %(_LibdaveConfig.Identity) built successfully." Importance="high" />

		<ItemGroup>
			<_LibdavePackageFiles Include="%(_LibdaveConfig.Dir)\**\*" Condition="Exists('%(_LibdaveConfig.Dir)')"/>
			<None Include="@(_LibdavePackageFiles)">
				<Pack>true</Pack>
				<PackagePath>native\$([MSBuild]::MakeRelative('$(LibdaveBuildDir)', '%(_LibdavePackageFiles.FullPath)'))</PackagePath>
			</None>
		</ItemGroup>
		
	</Target>

</Project>