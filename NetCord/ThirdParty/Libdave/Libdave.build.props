<Project>

	<!-- libdave CMake Build Integration -->
	<PropertyGroup>
		<BuildLibdave Condition="'$(BuildLibdave)' == ''">true</BuildLibdave>
		<AlsoCleanLibdave Condition="'$(AlsoCleanLibdave)' == ''">false</AlsoCleanLibdave>
		<LibdaveCppRoot>$(MSBuildThisFileDirectory)\libdave\cpp</LibdaveCppRoot>
		<LibdaveGenerator Condition="'$(LibdaveGenerator)' == ''"></LibdaveGenerator>
		<LibdaveBuildDir Condition="'$(LibdaveBuildDir)' == ''">$(MSBuildProjectDirectory)\$(BaseIntermediateOutputPath)\libdave_build</LibdaveBuildDir>
		<LibdaveBuildStampFile>$(LibdaveBuildDir)\.build-stamp</LibdaveBuildStampFile>
		<LibdaveConfigureErrorLog>$(LibdaveBuildDir)\.cmake-configure-error.log</LibdaveConfigureErrorLog>
		<LibdaveBuildErrorLog>$(LibdaveBuildDir)\.cmake-build-error.log</LibdaveBuildErrorLog>
		<LibdaveNativeLib Condition="'$(OS)' == 'Windows_NT'">dave.dll</LibdaveNativeLib>
		<LibdaveNativeLib Condition="'$(OS)' != 'Windows_NT' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'true'">libdave.dylib</LibdaveNativeLib>
		<LibdaveNativeLib Condition="'$(OS)' != 'Windows_NT' AND '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'true'">libdave.so</LibdaveNativeLib>
	</PropertyGroup>
	
</Project>
