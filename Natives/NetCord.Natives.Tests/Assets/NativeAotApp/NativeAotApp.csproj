<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PublishAot>true</PublishAot>
    <IsAotCompatible>true</IsAotCompatible>
    <SelfContained>true</SelfContained>
      
    <NetCordNativesDir Condition="'$(NetCordNativesDir)' == ''">..\..\..\NetCord.Natives</NetCordNativesDir>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\NativeProbes.cs" Condition="Exists('..\..\NativeProbes.cs')" />
  </ItemGroup>

	<ItemGroup>
		<DirectPInvoke Include="libdave" />
		<DirectPInvoke Include="libsodium" />
		<DirectPInvoke Include="opus" />
		<DirectPInvoke Include="zstd" />
		<ProjectReference Include="$(NetCordNativesDir)\NetCord.Natives.csproj" />
		<ProjectReference Include="$(NetCordNativesDir)\..\..\NetCord\NetCord.csproj" />
	</ItemGroup>
  <PropertyGroup>
    <NetCordExcludeNativesDynamic>libdave;libsodium;opus;zstd</NetCordExcludeNativesDynamic>
  </PropertyGroup>
	<Import Project="$(NetCordNativesDir)\NetCord.Natives.local.targets" />

</Project>
